# Copy to .env and fill in. Get credentials at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_api_key_here
TMDB_READ_TOKEN=your_read_access_token_here

# Postgres (local dev — pgvector container)
POSTGRES_DB=movies
POSTGRES_USER=movies
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
